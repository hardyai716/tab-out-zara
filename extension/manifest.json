{
  "manifest_version": 3,
  "name": "Tab Out",
  "version": "1.0.0",
  "description": "把新标签页变成标签页整理面板，按域名分组展示、跳转和关闭当前打开的网页。",
  "permissions": ["tabs", "activeTab", "storage"],
  "chrome_url_overrides": { "newtab": "index.html" },
  "background": { "service_worker": "background.js" },
  "action": {
    "default_title": "Tab Out",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
